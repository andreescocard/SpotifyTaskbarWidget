<Window x:Class="SpotifyTaskbarWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="480" Height="48"
        Left="0" Top="0"
        Loaded="Window_Loaded"
        MouseRightButtonUp="Window_MouseRightButtonUp">

    <Window.Resources>
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenProgress" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="PART_Track" Height="3">
                            <Border Background="#3D3D3D" CornerRadius="1.5"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="#1DB954" CornerRadius="1.5"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="6" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid Margin="8,0,6,0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="36"/>
                <ColumnDefinition Width="115"/>
                <ColumnDefinition Width="34"/>
                <ColumnDefinition Width="86"/>
                <ColumnDefinition Width="26"/>
                <ColumnDefinition Width="34"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Album art -->
            <Grid Grid.Column="0" Width="32" Height="32" HorizontalAlignment="Center">
                <Border Background="#2D2D2D" CornerRadius="3"/>
                <TextBlock Text="♪" Foreground="#555555" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding NoArtVisibility}"/>
                <Image Source="{Binding AlbumArt}" Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Clip>
                        <RectangleGeometry RadiusX="3" RadiusY="3" Rect="0,0,32,32"/>
                    </Image.Clip>
                </Image>
            </Grid>

            <!-- Title + Artist -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="7,0,4,0">
                <TextBlock Text="{Binding TrackTitle}" Foreground="#FFFFFF"
                           FontSize="11" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Artist}" Foreground="#B3B3B3"
                           FontSize="10" TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Elapsed -->
            <TextBlock Grid.Column="2" Text="{Binding ElapsedStr}"
                       Foreground="#B3B3B3" FontSize="10"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <!-- Controls: prev / play-pause / next -->
            <StackPanel Grid.Column="3" Orientation="Horizontal"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button Style="{StaticResource CtrlBtn}" Content="⏮"
                        Click="PrevButton_Click" ToolTip="Previous"/>
                <Button Style="{StaticResource CtrlBtn}" Content="{Binding PlayPauseIcon}"
                        Click="PlayPauseButton_Click" ToolTip="Play / Pause"
                        FontSize="14" Margin="2,0"/>
                <Button Style="{StaticResource CtrlBtn}" Content="⏭"
                        Click="NextButton_Click" ToolTip="Next"/>
            </StackPanel>

            <!-- Heart -->
            <Button Grid.Column="4" Style="{StaticResource CtrlBtn}"
                    Content="♡" Foreground="#B3B3B3"
                    Click="HeartButton_Click" ToolTip="Open Spotify to like"/>

            <!-- Total -->
            <TextBlock Grid.Column="5" Text="{Binding DurationStr}"
                       Foreground="#B3B3B3" FontSize="10"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <!-- Progress bar -->
            <ProgressBar Grid.Column="6" Style="{StaticResource GreenProgress}"
                         Value="{Binding ProgressPct}" Minimum="0" Maximum="100"
                         VerticalAlignment="Center" Margin="4,0,0,0"/>
        </Grid>
    </Border>
</Window>
